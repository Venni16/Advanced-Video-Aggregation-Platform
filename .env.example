# ════════════════════════════════════════════════
#  TAMIL GAMING VIDEO AGGREGATION PLATFORM
#  Environment Variables Template
#  Copy this file to .env and fill in your values
# ════════════════════════════════════════════════

# ── DATABASE ─────────────────────────────────────
POSTGRES_DB=tgvap
POSTGRES_USER=tgvap_user
POSTGRES_PASSWORD=your_strong_password_here
DATABASE_URL=postgresql://tgvap_user:your_strong_password_here@localhost:5432/tgvap

# ── REDIS ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── YOUTUBE DATA API v3 ───────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── BACKEND (Express.js) ─────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=generate_a_long_random_secret_here
CORS_ORIGIN=http://localhost:5173

# AI Service URL (internal or external)
AI_SERVICE_URL=http://localhost:8000

# Worker polling interval (milliseconds) — default 15 minutes
POLL_INTERVAL_MS=900000

# Max videos per YouTube API page (1–50)
YOUTUBE_MAX_RESULTS=50

# ── AI SERVICE (FastAPI + CLIP) ───────────────────
AI_SERVICE_PORT=8000
MODEL_NAME=openai/clip-vit-base-patch32
HF_HOME=./cache/huggingface

# ── FRONTEND ─────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001/api
VITE_APP_TITLE=TamilGaming.tv

# ── CORS / SECURITY ───────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
